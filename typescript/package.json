{
  "name": "rebac-primer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Learn TypeScript by implementing ReBAC authorization with OpenFGA.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "demo": "node src/demo/index.ts",
    "dev": "node --watch src/server/index.ts",
    "server": "node src/server/index.ts",
    "client": "node src/cli/index.ts",
    "start": "node src/server/index.ts",
    "check": "npm run build && npm run test"
  },
  "dependencies": {
    "@openfga/sdk": "0.9.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@vitest/coverage-v8": "^3.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
