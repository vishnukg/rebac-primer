{
  "name": "rebac-primer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Learn TypeScript by implementing ReBAC authorization with OpenFGA.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "authz": "node src/authz-service/index.ts",
    "documents": "node src/documents-service/index.ts",
    "start": "node src/authz-service/index.ts & node src/documents-service/index.ts & wait",
    "dev": "node --watch src/authz-service/index.ts & node --watch src/documents-service/index.ts",
    "client": "node src/cli/index.ts",
    "lint": "eslint src test",
    "audit": "node scripts/audit-factories.mjs",
    "check": "npm run build && npm run lint && npm run test && npm run audit"
  },
  "dependencies": {
    "@openfga/sdk": "0.9.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
